/* Universal Rate Calculator Positioning */
@media (min-width: 1025px) {
  /* The section containing the widget needs relative positioning */
  .elementor-section:has(#transcar-widget) > .elementor-container {
    position: relative !important;
  }
  
  /* The column containing the widget gets absol ute positioning */
  .elementor-column:has(#transcar-widget) {
    position: absolute !important;
    top: -280px !important;
    right: 0 !important;
    width: 45% !important;
    z-index: 99 !important;
  }
}

@media (max-width: 1024px) {
  .elementor-column:has(#transcar-widget) {
    margin-top: -50px !important;
    z-index: 99 !important;
    position: relative;
  }
}

/* Add slight padding around the widget inside its container */
.elementor-column:has(#transcar-widget) > .elementor-widget-wrap {
  padding: 15px !important;
}

/* Hard reset Elementor's min-height on the iframe */
#transcar-widget {
  min-height: 520px !important;
}

